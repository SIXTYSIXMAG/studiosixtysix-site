---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

export interface Props {
  entry: CollectionEntry<"work">;
  variant?: "index" | "featured";
}

const { entry, variant = "index" } = Astro.props;
const { title, client, services, heroImage } = entry.data;
const href = `/work/${entry.id}/`;
const alt = `${title} for ${client}`;
---

<article class="work-tile">
  <a href={href} class="block group" data-astro-prefetch>
    <div class="aspect-[4/5] overflow-hidden">
      <Image
        src={heroImage}
        alt={alt}
        widths={[480, 720, 960, 1200, 1440]}
        sizes="(min-width: 768px) 45vw, 100vw"
        class="h-full w-full object-cover"
      />
    </div>

    {
      variant === "featured" ? (
        <div class="mt-6">
          <hr class="mb-5" />
          <p class="text-lead">
            {title} <em>for</em> {client}
          </p>
          <p class="text-caption mt-2">{services.join(" · ")}</p>
        </div>
      ) : (
        <p class="text-caption mt-3">
          {title} — {client}
        </p>
      )
    }
  </a>
</article>

<style>
  .work-tile a {
    color: inherit;
    text-decoration: none;
  }
  .work-tile a:hover {
    text-decoration: none;
  }
</style>
