---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Studio"
  description="Studio Sixtysix is a creative consultancy in Chicago. Founded by Chris Force in 2018, we are the consulting practice of Sixtysix Magazine."
>
  <section class="container-base pb-16">
    <h1 class="text-display-l">Studio</h1>
  </section>

  <section class="container-base pb-20 max-w-3xl">
    <p class="text-body-l">
      Studio Sixtysix is a creative consultancy in Chicago. We help brands in the design and
      interior industry tell more meaningful stories, develop more original campaigns, and make
      better creative decisions. We work as fractional creative leadership, editorial producers,
      and strategic advisors.
    </p>
    <p class="text-body-l mt-6">
      Founded by Chris Force in 2018, we are the consulting practice of Sixtysix Magazine, the
      independent design and culture publication of the same name. Most of what we know we
      learned from making the magazine.
    </p>
  </section>

  <section class="container-base pb-16" aria-labelledby="magazine-section">
    <hr class="mb-8" />
    <h2 id="magazine-section" class="text-display-l">Magazine</h2>
    <p class="text-body-l mt-6 max-w-3xl">
      Sixtysix Magazine is an independent print and digital publication that covers the people,
      places, and ideas shaping contemporary design.
      <a href="https://sixtysixmag.com" rel="noopener">sixtysixmag.com</a>.
    </p>
  </section>

  <section class="container-base pb-16" aria-labelledby="press-section">
    <hr class="mb-8" />
    <h2 id="press-section" class="text-display-l">Press and Recognition</h2>
    <p class="text-caption mt-6">Coming soon.</p>
  </section>

  <section class="container-base pb-24" aria-labelledby="contact-section">
    <hr class="mb-8" />
    <h2 id="contact-section" class="text-display-l">Contact</h2>
    <dl class="text-body-l mt-6 grid max-w-md grid-cols-[auto_1fr] gap-x-6 gap-y-2">
      <dt class="text-caption">New projects</dt>
      <dd>
        <a href="mailto:hello@studiosixtysix.co">hello@studiosixtysix.co</a>
      </dd>
      <dt class="text-caption">Press</dt>
      <dd>
        <a href="mailto:press@studiosixtysix.co">press@studiosixtysix.co</a>
      </dd>
    </dl>
    <p class="text-body mt-6">Studio Sixtysix, Chicago, IL.</p>
  </section>
</BaseLayout>
