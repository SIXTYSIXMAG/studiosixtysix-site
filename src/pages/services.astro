---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services } from "../data/services";
---

<BaseLayout
  title="Services"
  description="Eight services from Studio Sixtysix: creative consulting, editorial production, concept development, editorial consultancy, events, environmental design, publishing, and digital."
>
  <section class="container-base pb-12">
    <h1 class="text-display-l">Services</h1>
  </section>

  <div class="container-base pb-24">
    {
      services.map((s) => (
        <section id={s.id} class="grid scroll-mt-12 grid-cols-1 gap-y-4 border-t border-[color:var(--color-rule)] py-12 md:grid-cols-12 md:gap-x-8">
          <h2 class="text-display-l md:col-span-7">{s.name}</h2>
          <div class="md:col-span-5">
            <p class="text-body-l max-w-md">{s.description}</p>
            <p class="text-caption mt-4 max-w-md">{s.engagements}</p>
            <a href="/work/" class="text-nav mt-6 inline-block" data-astro-prefetch>
              Selected work →
            </a>
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
